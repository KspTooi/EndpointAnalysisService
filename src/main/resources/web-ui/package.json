{
  "name": "webconsole",
  "version": "1.0A",
  "private": true,
  "type": "module",
  "scripts": {
    "//dev": "启动开发服务器。这是你的**“快乐摸鱼模式”**，支持热更新（HMR），你改一行代码，浏览器抖一下，让你觉得自己效率很高。",
    "dev": "vite",
    "//serve": "基本上是 dev 的僵尸变体。留着它是为了照顾那些还没从 Vue CLI 时代转过弯来的老古董们的肌肉记忆。",
    "serve": "vite",
    "//build": "终极缝合怪。使用 npm-run-all 工具并行（run-p）执行类型检查和构建。它的逻辑是：既然你都要发布了，那就一边检查报错一边打包，主打一个效率。",
    "build": "run-p type-check \"build-only {@}\" --",
    "//preview": "买家秀预览。它会本地启动一个服务器来运行你 dist 目录下的打包产物。因为开发环境（dev）是骗人的，只有 preview 里的东西才最接近用户看到的垃圾。",
    "preview": "vite preview",
    "//build-only": "这是真正的构建指令。它不管你的类型对不对，直接把源码丢进 Rollup 的粉碎机，吐出压缩后的 JS/CSS。它是**“唯结果论者”**。",
    "build-only": "vite build",
    "//type-check": "运行TS的类型检查。它专门负责挑刺。它不生成任何文件，只负责告诉你：你的类型定义又写烂了。",
    "type-check": "vue-tsc --build",
    "//lint": "代码审判日。ESLint 会逐行扫描你写的每一行 .vue/.ts/.js，把你那些'能跑就行'的骚操作全部揪出来挂在墙上示众。只看不改，适合自我反省用。",
    "lint": "eslint . --ext .vue,.ts,.js",
    "//lint:fix": "ESLint 的慈悲模式。发现问题后它会亲自动手替你擦屁股——能自动修复的它修复，修不了的它留给你，顺便鄙视你一眼。",
    "lint:fix": "eslint . --ext .vue,.ts,.js --fix",
    "//format": "格式化代码。它专门负责把你的代码变成人类能看懂的样子。",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,vue}\""
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@iconify/json": "^2.2.373",
    "@vue-office/docx": "^1.6.3",
    "@vue-office/excel": "^1.7.14",
    "axios": "1.12.0",
    "bootstrap-icons": "^1.11.3",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.12.0",
    "echarts": "^6.0.0",
    "element-plus": "2.11.3",
    "hash-wasm": "^4.12.0",
    "highlight.js": "^11.11.1",
    "json-editor-vue": "^0.18.1",
    "marked": "^15.0.7",
    "monaco-editor-vue3": "^0.1.10",
    "pinia": "^3.0.1",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pnpm": "^10.14.0",
    "splitpanes": "^4.0.4",
    "vanilla-jsoneditor": "^3.8.0",
    "vue": "^3.5.13",
    "vue-demi": "^0.14.10",
    "vue-echarts": "^8.0.1",
    "vue-json-pretty": "^2.5.0",
    "vue-router": "^4.5.0",
    "vue3-json-editor": "^1.1.5",
    "vuedraggable": "^4.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/postcss": "^4.1.16",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.13.9",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "npm-run-all2": "^7.0.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "sass-embedded": "^1.93.2",
    "tailwindcss": "^4.1.16",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.57.1",
    "unplugin-icons": "^22.2.0",
    "unplugin-vue-components": "^29.0.0",
    "vite": "^6.2.1",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vue-tsc": "^2.2.8"
  }
}
